never mutual_exclusion {    /* !([] (! ((in_cs[0]) && (in_cs[1])))) */
T0_init:
	do
	:: atomic { (! ((! ((in_cs[0]) && (in_cs[1]))))) -> assert(!(! ((! ((in_cs[0]) && (in_cs[1])))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
never non_starvation {    /* !([] (<> (cons_evt))) */
T0_init:
	do
	:: (! ((cons_evt))) -> goto accept_S4
	:: (1) -> goto T0_init
	od;
accept_S4:
	do
	:: (! ((cons_evt))) -> goto accept_S4
	od;
}
never producer_no_overwrite {    /* !([] ((! (prod_evt)) || ((prod_pre_flag==0)))) */
T0_init:
	do
	:: atomic { (! (((! (prod_evt)) || ((prod_pre_flag==0))))) -> assert(!(! (((! (prod_evt)) || ((prod_pre_flag==0)))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
