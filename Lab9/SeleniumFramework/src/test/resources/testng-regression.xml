<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" parallel="methods" thread-count="3">
    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <listeners>
        <listener class-name="com.example.seleniumframework.framework.utils.TestNameListener"/>
    </listeners>

    <test name="Regression Tests - All 3 Sheets">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="negative"/>
                <include name="boundary"/>
            </run>
        </groups>
        <classes>
            <class name="com.example.seleniumframework.tests.LoginDDTTest"/>
        </classes>
    </test>
</suite>