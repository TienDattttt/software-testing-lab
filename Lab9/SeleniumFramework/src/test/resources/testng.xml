<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SeleniumFramework" parallel="methods" thread-count="3">

    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <listeners>
        <listener class-name="com.example.seleniumframework.framework.utils.TestNameListener"/>
        <listener class-name="com.example.seleniumframework.framework.utils.RetryListener"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.example.seleniumframework.tests.LoginDDTTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.example.seleniumframework.tests.LoginDDTTest"/>
        </classes>
    </test>

    <test name="Login Tests">
        <classes>
            <class name="com.example.seleniumframework.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.example.seleniumframework.tests.CartTest"/>
        </classes>
    </test>


    <test name="JSON DDT Tests">
        <classes>
            <class name="com.example.seleniumframework.tests.UserLoginTest"/>
        </classes>
    </test>


    <test name="Faker Checkout Tests">
        <classes>
            <class name="com.example.seleniumframework.tests.FakerCheckoutTest"/>
        </classes>
    </test>

    <test name="Flaky Simulation Tests">
        <classes>
            <class name="com.example.seleniumframework.tests.FlakySimulationTest"/>
        </classes>
    </test>

</suite>
